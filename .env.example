# scribe service config. Copy to `.env` and fill in.
SCRIBE_DATABASE_URL=postgresql+psycopg://scribe:CHANGE_ME@10.10.0.13:13020/scribe
# Non-root runtime (#348): UID/GID 1001. The compose stack mounts a named
# volume here (scribe-tmp:/data/tmp); no host bind-mount to chown.
SCRIBE_TEMP_DIR=/data/tmp
# Directory holding transcript-summary.v*.md + .active. Operators bind-mount the
# <stack>/prompts dir here (see compose.yaml) and set this to /data/prompts.
SCRIBE_PROMPT_DIR=/data/prompts
# Wall-clock budget (seconds) for the yt-dlp download stage (#346). yt-dlp can
# hang indefinitely on a stuck stream; on expiry the yt-dlp process group is
# killed (no orphan) and the job fails with reason=download_timeout. 0 disables.
SCRIBE_DOWNLOAD_TIMEOUT_S=600
SCRIBE_VAST_API_KEY=CHANGE_ME
SCRIBE_VAST_BUDGET_BASELINE_USD_PER_HOUR=0.05
SCRIBE_VAST_BUDGET_ALERT_MULTIPLIER=5
SCRIBE_CODEX_BIN=codex
# codex model override. Empty = use the model selected by codex config.toml
# (gpt-5.x family). The ChatGPT-account codex on prod can't access the default
# gpt-5.3-codex, so prod pins gpt-5.5; set this if `codex exec` errors with a
# model-access/permission failure.
SCRIBE_CODEX_MODEL=
SCRIBE_SHORTLINK_BASE=http://go.oklabs.uk
SCRIBE_SHORTLINK_API_URL=http://10.10.0.25:25023/api/new
SCRIBE_SHORTLINK_API_KEY=CHANGE_ME
SCRIBE_PUBLIC_BASE_URL=http://10.10.0.13:13120
SCRIBE_WORKER_CONCURRENCY=1
# Hard ceiling (chars) on accepted summary output; pathological LLM output
# exceeding this is rejected (job marked summary-failed) instead of being
# persisted oversized. 0 disables the cap (not recommended).
SCRIBE_MAX_SUMMARY_CHARS=100000
# Map-reduce chunking for long transcripts (#382). When the built prompt
# (template + transcript) exceeds MAP_REDUCE_CHARS, the summary chain
# summarises the transcript in chunks (map) and merges the partials (reduce)
# so payload-limited backends (freellmapi) do not 413. CHUNK_CHARS caps the
# transcript chars per map call; OVERLAP_CHARS repeats a little context across
# chunk boundaries. 0 for MAP_REDUCE_CHARS disables map-reduce (always single
# pass). Short transcripts are unaffected.
SCRIBE_SUMMARY_MAP_REDUCE_CHARS=80000
SCRIBE_SUMMARY_MAP_REDUCE_CHUNK_CHARS=60000
SCRIBE_SUMMARY_MAP_REDUCE_OVERLAP_CHARS=500
# Legacy rollout setting; DB users are the product allowlist.
SCRIBE_AUTH_ALLOWED_EMAILS=
SCRIBE_AUTH_CLERK_ISSUER=https://example.clerk.accounts.dev
SCRIBE_AUTH_CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
SCRIBE_CLERK_BACKEND_API_URL=https://api.clerk.com
SCRIBE_CLERK_SECRET_KEY=
SCRIBE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SCRIBE_MACHINE_BEARER_TOKEN=CHANGE_ME
