{
  "manifest_version": 3,
  "name": "Scribe Video Submitter",
  "description": "Submit the current video page or link to a configured Scribe queue.",
  "version": "0.4.0",
  "action": {
    "default_title": "Submit video to Scribe",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "cookies",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://scribe.oklabs.uk/*"
  ],
  "optional_host_permissions": [
    "https://*.youtube.com/*",
    "https://youtu.be/*"
  ],
  "icons": {
    "16": "icons/scribe-16.png",
    "48": "icons/scribe-48.png",
    "128": "icons/scribe-128.png"
  }
}
